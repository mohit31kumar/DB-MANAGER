<%- include('partials/header') %>

<div class="row">
  <div class="col-md-3 sidebar">
    <h6 class="text-muted mb-2">Database: <strong><%= dbName %></strong></h6>
    <ul class="list-unstyled">
      <% tables.forEach(t => { %>
        <li>
          <a href="/table/<%= dbName %>/<%= t %>/browse" title="Browse"><i class="bi bi-table"></i> <%= t %></a>
        </li>
      <% }) %>
    </ul>
    <hr>
    <a href="/" class="btn btn-sm btn-outline-secondary w-100 mb-2"><i class="bi bi-arrow-left"></i> All Databases</a>
    <a href="/query" class="btn btn-sm btn-outline-primary w-100 mb-2"><i class="bi bi-terminal"></i> SQL Query</a>
    <a href="/import" class="btn btn-sm btn-outline-success w-100"><i class="bi bi-upload"></i> Import</a>
    <%- include('partials/credit') %>
  </div>
  <div class="col-md-9 main-content">
    <div class="d-flex justify-content-between align-items-center mb-3">
      <h4 class="mb-0">Database: <code><%= dbName %></code></h4>
    </div>

    <% if (typeof error !== 'undefined' && error) { %>
      <div class="alert alert-danger alert-dismissible fade show">
        <%= error %>
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
      </div>
    <% } %>

    <div class="table-responsive">
      <table class="table table-striped table-hover">
        <thead>
          <tr><th>#</th><th>Table Name</th><th>Actions</th></tr>
        </thead>
        <tbody>
          <% tables.forEach((t, i) => { %>
            <tr>
              <td><%= i + 1 %></td>
              <td><i class="bi bi-table"></i> <%= t %></td>
              <td>
                <a href="/table/<%= dbName %>/<%= t %>/structure" class="btn btn-sm btn-outline-info">Structure</a>
                <a href="/table/<%= dbName %>/<%= t %>/browse" class="btn btn-sm btn-outline-secondary">Browse</a>
              </td>
            </tr>
          <% }) %>
        </tbody>
      </table>
    </div>
    <p class="text-muted">Total: <%= tables.length %> table(s)</p>
  </div>
</div>

<%- include('partials/footer') %>
