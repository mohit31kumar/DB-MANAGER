<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>DB Manager</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
  <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.10.0/font/bootstrap-icons.css" rel="stylesheet">
  <link href="/css/style.css" rel="stylesheet">
</head>
<body>
  <nav class="navbar navbar-dark bg-dark px-3">
    <div class="d-flex align-items-center gap-3">
      <button class="mobile-toggle d-none" onclick="toggleSidebar()"><i class="bi bi-list"></i></button>
      <a class="navbar-brand" href="/"><i class="bi bi-database"></i> DB Manager</a>
    </div>
    <div class="d-flex align-items-center gap-2">
      <% if (typeof user !== 'undefined' && user) { %>
        <% if (typeof connConfig !== 'undefined' && connConfig) { %>
          <div class="dropdown">
            <button class="btn btn-outline-info btn-sm dropdown-toggle" data-bs-toggle="dropdown">
              <i class="bi bi-plug"></i> <%= connConfig.name %>
            </button>
            <ul class="dropdown-menu dropdown-menu-end">
              <% if (typeof userConns !== 'undefined') { %>
                <% userConns.forEach(c => { %>
                  <li>
                    <form method="POST" action="/connections/<%= c.id %>/activate" class="d-inline">
                      <button type="submit" class="dropdown-item <%= c.id === connId ? 'active' : '' %>">
                        <i class="bi bi-plug"></i> <%= c.name %>
                        <% if (c.id === connId) { %><span class="badge bg-success float-end">Active</span><% } %>
                      </button>
                    </form>
                  </li>
                <% }) %>
                <li><hr class="dropdown-divider"></li>
              <% } %>
              <li><a class="dropdown-item" href="/connections"><i class="bi bi-gear"></i> Manage Connections</a></li>
            </ul>
          </div>
        <% } else { %>
          <a href="/connections/add" class="btn btn-outline-warning btn-sm"><i class="bi bi-plus-circle"></i> Add Connection</a>
        <% } %>
        <a href="/query" class="btn btn-outline-light btn-sm d-none d-md-inline-flex align-items-center gap-1"><i class="bi bi-terminal"></i> Query</a>
        <a href="/import" class="btn btn-outline-light btn-sm d-none d-md-inline-flex align-items-center gap-1"><i class="bi bi-upload"></i> Import</a>
        <span class="text-light d-none d-sm-inline"><i class="bi bi-person"></i> <%= user.username %></span>
        <a href="/logout" class="btn btn-outline-light btn-sm">Logout</a>
      <% } %>
    </div>
  </nav>
  <div class="sidebar-overlay" onclick="toggleSidebar()"></div>
