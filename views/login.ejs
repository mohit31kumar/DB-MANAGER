<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Login - DB Manager</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
  <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.10.0/font/bootstrap-icons.css" rel="stylesheet">
  <link href="/css/style.css" rel="stylesheet">
  <style>
    .auth-split { min-height: 100vh; }
    .auth-left {
      background: linear-gradient(135deg, #0f0c29 0%, #302b63 50%, #24243e 100%);
      color: #fff;
      display: flex;
      flex-direction: column;
      justify-content: center;
      padding: 40px;
      position: relative;
      overflow: hidden;
    }
    @media (max-width: 768px) { .auth-left { display: none; } }

    /* 3D Floating Elements */
    .float-element {
      position: absolute;
      opacity: 0.15;
      animation: float3d 6s ease-in-out infinite;
      transform-style: preserve-3d;
      perspective: 500px;
    }
    .float-element i {
      display: block;
      animation: rotate3d 8s linear infinite;
      transform-style: preserve-3d;
    }
    .float-el-1 { top: 10%; right: 15%; font-size: 60px; animation-delay: 0s; }
    .float-el-2 { top: 25%; right: 35%; font-size: 40px; animation-delay: -2s; }
    .float-el-3 { bottom: 20%; right: 10%; font-size: 50px; animation-delay: -4s; }
    .float-el-4 { bottom: 35%; right: 30%; font-size: 35px; animation-delay: -1s; }
    .float-el-5 { top: 50%; right: 5%; font-size: 45px; animation-delay: -3s; }
    .float-el-6 { top: 15%; right: 50%; font-size: 30px; animation-delay: -5s; }

    @keyframes float3d {
      0%, 100% { transform: translateY(0) translateZ(0) rotateY(0deg); }
      25% { transform: translateY(-20px) translateZ(30px) rotateY(15deg); }
      50% { transform: translateY(-10px) translateZ(15px) rotateY(-10deg); }
      75% { transform: translateY(-25px) translateZ(40px) rotateY(10deg); }
    }
    @keyframes rotate3d {
      0% { transform: rotateX(0deg) rotateY(0deg); }
      25% { transform: rotateX(15deg) rotateY(15deg); }
      50% { transform: rotateX(0deg) rotateY(30deg); }
      75% { transform: rotateX(-15deg) rotateY(15deg); }
      100% { transform: rotateX(0deg) rotateY(0deg); }
    }

    /* Glow orbs */
    .glow-orb {
      position: absolute;
      border-radius: 50%;
      filter: blur(60px);
      opacity: 0.3;
    }
    .glow-1 { width: 200px; height: 200px; background: #6c63ff; top: 10%; left: -50px; }
    .glow-2 { width: 150px; height: 150px; background: #00d2ff; bottom: 20%; right: -30px; }
    .glow-3 { width: 120px; height: 120px; background: #ff6b6b; top: 60%; left: 20%; }

    /* Project cards */
    .project-card {
      border: 1px solid rgba(255,255,255,0.1);
      border-radius: 12px;
      padding: 14px;
      background: rgba(255,255,255,0.05);
      backdrop-filter: blur(10px);
      transition: all 0.4s cubic-bezier(0.175, 0.885, 0.32, 1.275);
      text-decoration: none;
      color: inherit;
      display: block;
      transform-style: preserve-3d;
      perspective: 500px;
    }
    .project-card:hover {
      transform: translateY(-6px) rotateX(5deg) rotateY(-3deg);
      box-shadow: 0 20px 40px rgba(0,0,0,0.3);
      border-color: rgba(108,99,255,0.5);
      background: rgba(255,255,255,0.1);
    }
    .project-card .icon-box {
      width: 38px; height: 38px; border-radius: 8px;
      display: flex; align-items: center; justify-content: center;
      font-size: 16px; transition: transform 0.3s;
    }
    .project-card:hover .icon-box { transform: translateZ(10px) scale(1.1); }
    .project-card h6 { font-size: 13px; font-weight: 600; margin-bottom: 3px; }
    .project-card p { font-size: 11px; color: rgba(255,255,255,0.5); margin-bottom: 0; line-height: 1.4; }
    .project-card .badge { font-size: 9px; }
  </style>
</head>
<body class="bg-light">
  <div class="container-fluid p-0">
    <div class="row auth-split g-0">
      <div class="col-md-6 auth-left">
        <div class="glow-orb glow-1"></div>
        <div class="glow-orb glow-2"></div>
        <div class="glow-orb glow-3"></div>

        <div class="float-element float-el-1"><i class="bi bi-database"></i></div>
        <div class="float-element float-el-2"><i class="bi bi-person-bounding-box"></i></div>
        <div class="float-element float-el-3"><i class="bi bi-rocket-takeoff"></i></div>
        <div class="float-element float-el-4"><i class="bi bi-shield-lock"></i></div>
        <div class="float-element float-el-5"><i class="bi bi-code-slash"></i></div>
        <div class="float-element float-el-6"><i class="bi bi-terminal"></i></div>

        <div class="position-relative" style="z-index: 2;">
          <div class="mb-4">
            <i class="bi bi-database" style="font-size: 48px; opacity: 0.9;"></i>
            <h2 class="mt-3 fw-bold">DB Manager</h2>
            <p class="text-white-50 mb-4">A powerful web-based database management tool built with Node.js</p>
          </div>
          <h6 class="text-white-50 mb-3">More Projects by Mohit Kumar</h6>
          <div class="d-flex flex-column gap-3">
            <a href="https://github.com/mohit31kumar/face-unlock" target="_blank" class="project-card">
              <div class="d-flex align-items-start gap-3">
                <div class="icon-box bg-success bg-opacity-25 text-success"><i class="bi bi-person-bounding-box"></i></div>
                <div>
                  <h6 class="mb-1">face-unlock</h6>
                  <p>PAM-based facial authentication for Linux</p>
                  <span class="badge bg-success bg-opacity-25 text-success">Python</span>
                  <span class="badge bg-warning bg-opacity-25 text-warning">Apache 2.0</span>
                </div>
              </div>
            </a>
            <a href="https://github.com/mohit31kumar/ufosay" target="_blank" class="project-card">
              <div class="d-flex align-items-start gap-3">
                <div class="icon-box bg-info bg-opacity-25 text-info"><i class="bi bi-rocket-takeoff"></i></div>
                <div>
                  <h6 class="mb-1">ufosay</h6>
                  <p>A flying saucer terminal animation tool</p>
                  <span class="badge bg-info bg-opacity-25 text-info">Python</span>
                  <span class="badge bg-primary bg-opacity-25 text-primary">MIT</span>
                </div>
              </div>
            </a>
          </div>
        </div>
      </div>
      <div class="col-md-6 d-flex align-items-center justify-content-center" style="min-height: 100vh;">
        <div style="width: 100%; max-width: 380px; padding: 20px;">
          <div class="text-center mb-4">
            <i class="bi bi-database" style="font-size: 36px; color: var(--primary);"></i>
            <h5 class="mt-2 mb-0">Welcome Back</h5>
            <small class="text-muted">Sign in to DB Manager</small>
          </div>
          <% if (error) { %>
            <div class="alert alert-danger py-2"><%= error %></div>
          <% } %>
          <form method="POST" action="/login">
            <div class="mb-3">
              <label for="username" class="form-label">Username</label>
              <div class="input-group input-group-sm">
                <span class="input-group-text"><i class="bi bi-person"></i></span>
                <input type="text" class="form-control" id="username" name="username" value="<%= username %>" required autofocus>
              </div>
            </div>
            <div class="mb-3">
              <label for="password" class="form-label">Password</label>
              <div class="input-group input-group-sm">
                <span class="input-group-text"><i class="bi bi-lock"></i></span>
                <input type="password" class="form-control" id="password" name="password" required>
              </div>
            </div>
            <button type="submit" class="btn btn-primary w-100 btn-sm">Sign In</button>
          </form>
          <div class="text-center mt-3">
            <small class="text-muted">Don't have an account? <a href="/register">Create one</a></small>
          </div>
          <div class="text-center mt-4 pt-3 border-top">
            <small class="text-muted">Built by <a href="https://github.com/mohit31kumar" target="_blank">Mohit Kumar</a></small>
          </div>
        </div>
      </div>
    </div>
  </div>
</body>
</html>
